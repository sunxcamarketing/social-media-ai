{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "voice-server": "npx tsx --require dotenv/config src/voice-server.ts",
    "inngest": "npx inngest-cli@latest dev -u http://localhost:4000/api/inngest",
    "all": "concurrently --kill-others-on-fail --names 'NEXT,VOICE,INNGEST' --prefix-colors 'blue,magenta,yellow' 'npm run dev' 'npm run voice-server' 'npm run inngest'"
  },
