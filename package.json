    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "html-to-image": "^1.11.13",
    "inngest": "^3.54.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "15.3.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
